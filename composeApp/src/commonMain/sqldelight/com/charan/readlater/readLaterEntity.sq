CREATE TABLE readLaterEntity (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    url TEXT NOT NULL,
    title TEXT,
    description TEXT,
    created_at INTEGER NOT NULL,
    is_due INTEGER NOT NULL DEFAULT 0
    );


insertReadLaterItem:
INSERT OR REPLACE INTO readLaterEntity (id, url, title, description, created_at, is_due)
VALUES (?, ?, ?, ?, ?, ?);

getAllReadLaterItems:
SELECT * FROM readLaterEntity;
